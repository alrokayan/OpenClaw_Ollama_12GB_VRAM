# Secrets -------------------------------------------------------------
# The token file this script reads is named "env" (no leading dot).
# A bare ".env" rule would NOT match it.
env
.env
*.env
!env.example
secrets
secrets.*

# OpenClaw config snapshots this script leaves behind.
# These can contain a plaintext gateway token.
openclaw.json
openclaw.json.*
*.post-ollama-launch
*.rejected.*
*.clobbered.*
*.bak.*
*.last-good

# Android / emulator ---------------------------------------------------
*.apk
*.xapk
*.apks
*.obb

# Windows / editors ----------------------------------------------------
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~